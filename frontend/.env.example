# Used in src/app/layout.tsx for metadataBase / Open Graph URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB connection string — from Atlas (or your own instance).
# Example: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/visit-sri-lanka
MONGODB_URI=

# Auth.js (NextAuth v5) — required in production, optional in dev (a dev
# secret is auto-generated, but set one explicitly to avoid session resets
# on every restart). Generate with: npx auth secret
AUTH_SECRET=
# Only needed if your deployed URL differs from what Auth.js infers
# automatically (usually not needed on Vercel).
# AUTH_URL=http://localhost:3000

# Google Analytics 4 (Phase 10) — leave blank in local dev
NEXT_PUBLIC_GA_ID=

# Reserved for future phases — not used yet
# NEXT_PUBLIC_API_BASE_URL=
