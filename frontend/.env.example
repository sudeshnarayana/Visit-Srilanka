# Used in src/app/layout.tsx for metadataBase / Open Graph URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Phase 9) — from your project's Settings > API page
NEXT_PUBLIC_SUPABASE_URL=test
NEXT_PUBLIC_SUPABASE_ANON_KEY=test
# Server-only — never prefix with NEXT_PUBLIC_, never send to the browser.
# Used only in trusted server contexts (e.g. an admin route handler), not
# in lib/api/destinations.ts or hotels.ts, which use the anon key + RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Google Analytics 4 (Phase 10) — leave blank in local dev
NEXT_PUBLIC_GA_ID=

# Reserved for future phases — not used yet
# NEXT_PUBLIC_API_BASE_URL=
